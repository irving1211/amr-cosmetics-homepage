{% comment %}
  AMR Header — announcement bar + three-column nav with mobile drawer.
  Logo uses Arapey italic to match the live store mark (or falls back to a PNG upload).
{% endcomment %}

{{ 'amr-homepage.css' | asset_url | stylesheet_tag }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Arapey:ital@0;1&display=swap" rel="stylesheet">

<style>
  .amr-mark {
    font-family: "Arapey", serif;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--amr-ink);
    line-height: 1;
    display: inline-block;
    text-decoration: none;
  }
  .amr-mark--md { font-size: clamp(26px, 3vw, 32px); }
  .amr-mark--sm { font-size: 20px; }
  .amr-mark__sub {
    display: block;
    font-family: var(--amr-font-body);
    font-style: normal;
    font-size: 0.36em;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--amr-ink);
    margin-top: 0.3em;
    line-height: 1;
  }
  .amr-mark--sm .amr-mark__sub { font-size: 0.55em; letter-spacing: 0.28em; margin-top: 0.35em; }

  .amr-announce {
    background: var(--amr-cocoa);
    color: var(--amr-paper-warm);
    padding: 10px 20px; text-align: center;
    font-family: var(--amr-font-body); font-size: 12px;
    letter-spacing: 0.18em; text-transform: uppercase;
  }
  .amr-nav {
    position: relative;
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
    padding: 20px clamp(20px, 5vw, 80px);
    background: var(--amr-paper);
    border-bottom: 1px solid var(--amr-hairline);
    gap: 24px;
  }
  .amr-nav__left { display: flex; gap: 28px; align-items: center; font-size: 13px; letter-spacing: 0.04em; color: var(--amr-ink); }
  .amr-nav__right { display: flex; gap: 22px; align-items: center; justify-content: flex-end; font-size: 13px; letter-spacing: 0.04em; color: var(--amr-ink); }
  .amr-nav__left a, .amr-nav__right a { color: inherit; text-decoration: none; transition: opacity .2s; }
  .amr-nav__left a:hover, .amr-nav__right a:hover { opacity: 0.6; }

  .amr-nav__burger { display: none; width: 28px; height: 28px; background: none; border: 0; cursor: pointer; padding: 0; position: relative; }
  .amr-nav__burger span { position: absolute; left: 0; right: 0; height: 1.5px; background: var(--amr-ink); transition: transform .25s var(--amr-ease); }
  .amr-nav__burger span:nth-child(1) { top: 8px; }
  .amr-nav__burger span:nth-child(2) { top: 50%; transform: translateY(-50%); }
  .amr-nav__burger span:nth-child(3) { bottom: 8px; }

  @media (max-width: 820px) {
    .amr-nav { padding: 16px 20px; }
    .amr-nav__left, .amr-nav__right { gap: 18px; font-size: 12px; }
    .amr-nav__left a:not(.amr-nav__burger),
    .amr-nav__right a:not(.amr-nav__cart) { display: none; }
    .amr-nav__burger { display: block; }
  }

  .amr-drawer {
    position: fixed; inset: 0; z-index: 100;
    background: var(--amr-paper);
    padding: 24px clamp(24px, 6vw, 40px);
    display: flex; flex-direction: column; gap: 24px;
    transform: translateX(-100%); transition: transform .35s var(--amr-ease); visibility: hidden;
  }
  .amr-drawer[aria-hidden="false"] { transform: translateX(0); visibility: visible; }
  .amr-drawer__head { display: flex; align-items: center; justify-content: space-between; }
  .amr-drawer__close { width: 28px; height: 28px; border: 0; background: none; cursor: pointer; padding: 0; font-size: 24px; line-height: 1; color: var(--amr-ink); }
  .amr-drawer__nav { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 20px; margin-top: 24px; }
  .amr-drawer__nav a { font-family: var(--amr-font-display); font-size: clamp(28px, 6vw, 36px); color: var(--amr-ink); text-decoration: none; line-height: 1.2; }
  .amr-drawer__nav a:hover { color: var(--amr-cocoa); }
  .amr-drawer__sub { display: flex; flex-direction: column; gap: 12px; margin-top: auto; padding-top: 24px; border-top: 1px solid var(--amr-hairline); }
  .amr-drawer__sub a { font-size: 14px; letter-spacing: 0.04em; color: var(--amr-ink-soft); text-decoration: none; }
</style>

{%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
  <div class="amr-announce">{{ section.settings.announcement_text }}</div>
{%- endif -%}

<header class="amr-nav" role="banner">
  <nav class="amr-nav__left" aria-label="Shop navigation">
    <button class="amr-nav__burger" type="button" aria-label="Open menu" aria-controls="amr-mobile-drawer" aria-expanded="false" data-amr-drawer-open>
      <span></span><span></span><span></span>
    </button>
    {%- for link in linklists[section.settings.header_menu].links limit: 4 -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- else -%}
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      <a href="/collections/hair-care">Hair</a>
      <a href="/collections/lip-care">Lip</a>
      <a href="{{ routes.all_products_collection_url }}">All</a>
    {%- endfor -%}
  </nav>

  {%- if section.settings.script_logo != blank -%}
    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} — home">
      <img
        src="{{ section.settings.script_logo | image_url: width: 240 }}"
        srcset="{{ section.settings.script_logo | image_url: width: 240 }} 1x, {{ section.settings.script_logo | image_url: width: 480 }} 2x"
        width="{{ section.settings.script_logo.width }}"
        height="{{ section.settings.script_logo.height }}"
        alt="{{ shop.name }}"
        loading="eager"
        fetchpriority="high"
        style="height: clamp(34px, 4vw, 44px); width: auto; display: block;"
      >
    </a>
  {%- else -%}
    <a href="{{ routes.root_url }}" class="amr-mark amr-mark--md" aria-label="{{ shop.name }} — home">
      AMR<span class="amr-mark__sub">Cosmetics</span>
    </a>
  {%- endif -%}

  <nav class="amr-nav__right" aria-label="Account navigation">
    <a href="{{ routes.search_url }}" aria-label="Search">Search</a>
    {%- if shop.customer_accounts_enabled -%}
      <a href="{{ routes.account_url }}" aria-label="Account">Account</a>
    {%- endif -%}
    <a class="amr-nav__cart" href="{{ routes.cart_url }}" aria-label="Cart">Cart ({{ cart.item_count }})</a>
  </nav>
</header>

<aside class="amr-drawer" id="amr-mobile-drawer" aria-hidden="true" aria-label="Mobile navigation">
  <div class="amr-drawer__head">
    <a href="{{ routes.root_url }}" class="amr-mark amr-mark--sm" aria-label="{{ shop.name }} — home">
      AMR<span class="amr-mark__sub">Cosmetics</span>
    </a>
    <button class="amr-drawer__close" type="button" aria-label="Close menu" data-amr-drawer-close>&times;</button>
  </div>
  <ul class="amr-drawer__nav">
    {%- for link in linklists[section.settings.header_menu].links -%}
      <li><a href="{{ link.url }}" data-amr-drawer-link>{{ link.title }}</a></li>
    {%- else -%}
      <li><a href="{{ routes.all_products_collection_url }}" data-amr-drawer-link>Shop</a></li>
      <li><a href="/collections/hair-care" data-amr-drawer-link>Hair Care</a></li>
      <li><a href="/collections/lip-care" data-amr-drawer-link>Lip Care</a></li>
      <li><a href="{{ routes.all_products_collection_url }}" data-amr-drawer-link>All Products</a></li>
    {%- endfor -%}
  </ul>
  <div class="amr-drawer__sub">
    <a href="{{ routes.search_url }}">Search</a>
    {%- if shop.customer_accounts_enabled -%}
      <a href="{{ routes.account_url }}">Account</a>
    {%- endif -%}
    <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
    {%- if section.settings.instagram_url != blank -%}
      <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">@amr.cosmeticss</a>
    {%- endif -%}
  </div>
</aside>

<script>
  (function(){
    var openBtn = document.querySelector('[data-amr-drawer-open]');
    var closeBtn = document.querySelector('[data-amr-drawer-close]');
    var drawer = document.getElementById('amr-mobile-drawer');
    if (!openBtn || !closeBtn || !drawer) return;
    function open() { drawer.setAttribute('aria-hidden', 'false'); openBtn.setAttribute('aria-expanded', 'true'); document.body.style.overflow = 'hidden'; }
    function close() { drawer.setAttribute('aria-hidden', 'true'); openBtn.setAttribute('aria-expanded', 'false'); document.body.style.overflow = ''; }
    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    drawer.querySelectorAll('[data-amr-drawer-link]').forEach(function(a){ a.addEventListener('click', close); });
    document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') close(); });
  })();
</script>

{% schema %}
{
  "name": "AMR Header",
  "tag": "header",
  "class": "amr-header-section",
  "settings": [
    { "type": "header", "content": "Announcement bar" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Complimentary shipping on orders over $50" },
    { "type": "header", "content": "Identity" },
    { "type": "image_picker", "id": "script_logo", "label": "Logo image (PNG, optional)", "info": "If empty, falls back to 'AMR / Cosmetics' in Arapey italic — matching the live store mark." },
    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "header_menu", "label": "Header menu (max 4 items shown on desktop)" },
    { "type": "header", "content": "Mobile drawer extras" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL", "default": "https://www.instagram.com/amr.cosmeticss/" }
  ],
  "presets": [
    { "name": "AMR Header", "category": "AMR" }
  ]
}
{% endschema %}
