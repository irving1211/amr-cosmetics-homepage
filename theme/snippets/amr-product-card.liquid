{% comment %}
  AMR Product Card snippet
  Inputs:
    - product: Shopify product object (required)
    - eyebrow: small uppercase string above title (optional)
    - aspect: 'portrait' (default) | 'square'
    - show_second_image: bool — fade-to-second-image on hover (default true)
{% endcomment %}

{%- liquid
  assign aspect = aspect | default: 'portrait'
  if show_second_image == nil
    assign show_second_image = true
  endif
  assign first_image = product.featured_image
  assign second_image = product.images[1]
-%}

<a
  class="amr-product-card amr-product-card--{{ aspect }}"
  href="{{ product.url }}"
  aria-label="{{ product.title | escape }}"
>
  <div class="amr-product-card__media">
    {%- if first_image != blank -%}
      <img
        class="amr-product-card__image amr-product-card__image--primary"
        src="{{ first_image | image_url: width: 900 }}"
        srcset="
          {{ first_image | image_url: width: 450 }} 450w,
          {{ first_image | image_url: width: 700 }} 700w,
          {{ first_image | image_url: width: 900 }} 900w,
          {{ first_image | image_url: width: 1200 }} 1200w
        "
        sizes="(min-width: 1024px) 22vw, (min-width: 600px) 45vw, 90vw"
        width="{{ first_image.width }}"
        height="{{ first_image.height }}"
        alt="{{ first_image.alt | default: product.title | escape }}"
        loading="lazy"
      >
      {%- if show_second_image and second_image != blank -%}
        <img
          class="amr-product-card__image amr-product-card__image--secondary"
          src="{{ second_image | image_url: width: 900 }}"
          srcset="
            {{ second_image | image_url: width: 450 }} 450w,
            {{ second_image | image_url: width: 700 }} 700w,
            {{ second_image | image_url: width: 900 }} 900w
          "
          sizes="(min-width: 1024px) 22vw, (min-width: 600px) 45vw, 90vw"
          width="{{ second_image.width }}"
          height="{{ second_image.height }}"
          alt=""
          loading="lazy"
          aria-hidden="true"
        >
      {%- endif -%}
    {%- else -%}
      <div class="amr-product-card__placeholder" aria-hidden="true"></div>
    {%- endif -%}
  </div>

  <div class="amr-product-card__caption">
    {%- if eyebrow != blank -%}
      <p class="amr-eyebrow amr-product-card__eyebrow">{{ eyebrow }}</p>
    {%- endif -%}
    <h3 class="amr-product-card__title">{{ product.title }}</h3>
    <p class="amr-product-card__price">
      {%- if product.compare_at_price > product.price -%}
        <span class="amr-product-card__price-sale">{{ product.price | money }}</span>
        <span class="amr-product-card__price-compare">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </p>
  </div>
</a>
